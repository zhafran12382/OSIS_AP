# ===========================================
# OSIS AP — Environment Variables
# ===========================================
# Salin file ini menjadi .env.local:
#   cp .env.example .env.local
# Lalu isi dengan nilai dari dashboard Supabase Anda.

# ------ Supabase (WAJIB) ------
# Dapatkan dari: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ------ Admin Login (OPSIONAL) ------
# Default: AdminNFBS / admin
# Ubah untuk keamanan production!
ADMIN_USERNAME=AdminNFBS
ADMIN_PASSWORD=admin
